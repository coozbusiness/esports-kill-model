{
  "manifest_version": 3,
  "name": "Esports Kill Model — PrizePicks Auto-Import",
  "version": "1.0.0",
  "description": "Automatically captures PrizePicks props and sends them to your kill model app",
  "permissions": [
    "webRequest",
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://api.prizepicks.com/*",
    "https://*.prizepicks.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.prizepicks.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
